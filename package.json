{
  "name": "vscode-remote-file-transfer",
  "displayName": "Remote File Transfer",
  "description": "Transfer medium and small files between isolated Remote-SSH windows via local staging.",
  "version": "0.0.2",
  "publisher": "LiaoJianjin",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/liaojianjin/vscode-remote-file-transfer.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "scripts": {
    "clean": "rm -rf out",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && npx @vscode/vsce package",
    "pretest": "npm run compile",
    "test": "node --test \"out/test/**/*.test.js\""
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "onCommand:remoteFileTransfer.stageFiles",
    "onCommand:remoteFileTransfer.fetchFiles",
    "onCommand:remoteFileTransfer.deleteStagedFiles",
    "onCommand:remoteFileTransfer.deleteSingleStagedFile",
    "onCommand:remoteFileTransfer.refreshStagingView",
    "onView:remoteFileTransfer.stagingView"
  ],
  "contributes": {
    "commands": [
      {
        "command": "remoteFileTransfer.stageFiles",
        "title": "📤 暂存到全局池",
        "category": "Remote File Transfer"
      },
      {
        "command": "remoteFileTransfer.fetchFiles",
        "title": "📥 从全局池拉取...",
        "category": "Remote File Transfer"
      },
      {
        "command": "remoteFileTransfer.deleteStagedFiles",
        "title": "🗑️ 删除全局池文件...",
        "category": "Remote File Transfer"
      },
      {
        "command": "remoteFileTransfer.deleteSingleStagedFile",
        "title": "🗑️ 删除该暂存文件",
        "category": "Remote File Transfer"
      },
      {
        "command": "remoteFileTransfer.refreshStagingView",
        "title": "刷新暂存池视图",
        "icon": "$(refresh)",
        "category": "Remote File Transfer"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "remoteFileTransfer.stagingView",
          "name": "Global Staging Pool"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "remoteFileTransfer.stageFiles",
          "group": "navigation@80",
          "when": "explorerViewletVisible && (resourceScheme == file || resourceScheme == vscode-remote)"
        },
        {
          "command": "remoteFileTransfer.fetchFiles",
          "group": "navigation@81",
          "when": "explorerViewletVisible && explorerResourceIsFolder && (resourceScheme == file || resourceScheme == vscode-remote)"
        },
        {
          "command": "remoteFileTransfer.deleteStagedFiles",
          "group": "navigation@82",
          "when": "explorerViewletVisible && (resourceScheme == file || resourceScheme == vscode-remote)"
        }
      ],
      "view/title": [
        {
          "command": "remoteFileTransfer.refreshStagingView",
          "when": "view == remoteFileTransfer.stagingView",
          "group": "navigation@1"
        },
        {
          "command": "remoteFileTransfer.deleteStagedFiles",
          "when": "view == remoteFileTransfer.stagingView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "remoteFileTransfer.deleteSingleStagedFile",
          "when": "view == remoteFileTransfer.stagingView && (viewItem == stagedFile || viewItem == stagedFolder)",
          "group": "inline@1"
        }
      ],
      "commandPalette": [
        {
          "command": "remoteFileTransfer.stageFiles",
          "when": "resourceScheme == file || resourceScheme == vscode-remote"
        },
        {
          "command": "remoteFileTransfer.fetchFiles",
          "when": "resourceScheme == file || resourceScheme == vscode-remote"
        },
        {
          "command": "remoteFileTransfer.deleteStagedFiles",
          "when": "resourceScheme == file || resourceScheme == vscode-remote"
        },
        {
          "command": "remoteFileTransfer.refreshStagingView",
          "when": "resourceScheme == file || resourceScheme == vscode-remote"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.8.3"
  }
}
